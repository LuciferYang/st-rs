<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.forstdb</groupId>
    <artifactId>st-rs-flink-it</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>st-rs Flink integration tests</name>
    <description>End-to-end integration tests that run a real Flink MiniCluster
        with Flink's ForSt state backend pointed at the st-rs JNI wrapper
        instead of upstream forstjni.</description>

    <properties>
        <java.version>17</java.version>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <flink.version>2.2.0</flink.version>
        <junit.version>5.10.2</junit.version>
        <st-rs-jni.version>0.0.1-SNAPSHOT</st-rs-jni.version>
    </properties>

    <dependencies>
        <!-- st-rs JNI wrapper. Must be installed to local Maven repo before
             running tests (mvn install in ../java/). Provides the
             org.forstdb.* classes that Flink's ForSt backend talks to. -->
        <dependency>
            <groupId>org.forstdb</groupId>
            <artifactId>st-rs-jni</artifactId>
            <version>${st-rs-jni.version}</version>
        </dependency>

        <!-- Flink's ForSt state backend. We exclude com.ververica:forstjni
             so our st-rs-jni provides the org.forstdb.* implementations. -->
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-statebackend-forst</artifactId>
            <version>${flink.version}</version>
            <scope>test</scope>
            <exclusions>
                <exclusion>
                    <groupId>com.ververica</groupId>
                    <artifactId>forstjni</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-streaming-java</artifactId>
            <version>${flink.version}</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-test-utils</artifactId>
            <version>${flink.version}</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-test-utils-junit</artifactId>
            <version>${flink.version}</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <!-- Point java.library.path at the cargo build output so
                         NativeLibraryLoader.System.loadLibrary("st_rs_jni")
                         finds libst_rs_jni.{so,dylib}. CI sets this; locally
                         override with -Djava.library.path=... if needed. -->
                    <argLine>-Djava.library.path=${project.basedir}/../target/debug --add-opens=java.base/java.util=ALL-UNNAMED --add-opens=java.base/java.lang=ALL-UNNAMED</argLine>
                    <!-- Include *IT.java since this module is integration
                         tests; surefire's default pattern excludes them. -->
                    <includes>
                        <include>**/*IT.java</include>
                        <include>**/*Test.java</include>
                    </includes>
                    <!-- Stream test output live so a hang shows where it
                         got stuck instead of disappearing into a buffered
                         report file we never see. -->
                    <useFile>false</useFile>
                    <trimStackTrace>false</trimStackTrace>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
