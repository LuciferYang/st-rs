<!--
  Surfaces Flink runtime + ForSt backend logs during the IT so a job
  init failure shows up instead of being silently swallowed by
  executeAndCollect's poll loop. Without this config log4j2 defaults
  to ERROR-only and we see nothing.
-->
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} %-5p %-30c{1} - %m%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Logger name="org.apache.flink" level="INFO"/>
        <Logger name="org.apache.flink.runtime.checkpoint" level="INFO"/>
        <Logger name="org.apache.flink.state.forst" level="TRACE"/>
        <Logger name="org.apache.flink.state.forst.datatransfer" level="TRACE"/>
        <Logger name="org.apache.flink.runtime.state" level="DEBUG"/>
        <Logger name="org.forstdb" level="DEBUG"/>
        <!-- Akka / pekko + zookeeper get noisy fast. -->
        <Logger name="org.apache.pekko" level="WARN"/>
        <Logger name="akka" level="WARN"/>
        <Root level="WARN">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
